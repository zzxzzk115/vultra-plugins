{
  "schemaVersion": 2,
  "kind": "vultra.pluginCatalog",
  "name": "Vultra Plugins",
  "repository": "https://github.com/zzxzzk115/vultra-plugins",
  "defaultInstallRoot": "<asset-root>/plugins",
  "plugins": [
    {
      "id": "com.vultra.examples.hello",
      "name": "Hello",
      "author": "Vultra",
      "repository": "https://github.com/zzxzzk115/vultra-plugin-hello",
      "readme": "https://github.com/zzxzzk115/vultra-plugin-hello/blob/main/README.md",
      "capabilities": ["lua"],
      "platforms": ["windows", "linux", "macos"],
      "description": "Pure Lua plugin example.",
      "version": "0.1.0",
      "source": {
        "type": "git",
        "url": "https://github.com/zzxzzk115/vultra-plugin-hello.git",
        "ref": "v0.1.0"
      },
      "versions": [
        {
          "version": "0.1.0",
          "notes": "Initial release.",
          "source": {
            "type": "git",
            "url": "https://github.com/zzxzzk115/vultra-plugin-hello.git",
            "ref": "v0.1.0"
          }
        }
      ]
    },
    {
      "id": "com.vultra.dlss",
      "name": "Streamline Upscaler",
      "author": "Vultra",
      "repository": "https://github.com/zzxzzk115/vultra-plugin-streamline",
      "readme": "https://github.com/zzxzzk115/vultra-plugin-streamline/blob/main/README.md",
      "capabilities": ["native", "lua", "render_pass", "upscaler"],
      "platforms": ["windows"],
      "description": "NVIDIA Streamline / DLSS upscaler plugin. Streamline runtime DLLs are bundled; no environment configuration needed.",
      "version": "0.1.0",
      "source": {
        "type": "git",
        "url": "https://github.com/zzxzzk115/vultra-plugin-streamline.git",
        "ref": "v0.1.0"
      },
      "versions": [
        {
          "version": "0.1.0",
          "notes": "Initial release. Streamline runtime resolves from the plugin root; environment variables are build-time only.",
          "source": {
            "type": "git",
            "url": "https://github.com/zzxzzk115/vultra-plugin-streamline.git",
            "ref": "v0.1.0"
          }
        }
      ]
    }
  ]
}
